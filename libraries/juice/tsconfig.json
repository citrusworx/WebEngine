{
    "extends": "../../tsconfig.base.json",
    "include": [
        "src/**/*"
    ],

    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "rootDir": "src",
        "outDir": "dist",
        "jsx": "react-jsx",
        "jsxImportSource": "@citrusworx/sigjs",
        "strict": true,
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true
    }
}