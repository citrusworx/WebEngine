{
    "compilerOptions": {
        "baseUrl": "/.",

        "target": "es2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "declaration": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "paths": {
            "@citrusworx/types": ["libraries/types/src"],
            "@citrusworx/types/*": ["libraries/types/src/*"]
        }
    }
}